# Vercel Environment Variables - Set these in Vercel Dashboard

# Frontend
PUBLIC_API_URL=https://backend-app.vercel.app/api/v1
PUBLIC_MASTER_API_URL=https://backend-app.vercel.app/api/v1

# Backend (separate Vercel project or hosted service)
DATABASE_URL=postgresql://user:password@host:5432/db
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SALT_ROUNDS=12
SENTRI_API_KEY=your-secret-api-key
CLIENT_URL=https://frontend-app.vercel.app
PORT=3000
